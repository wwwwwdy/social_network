{
  "info": {
    "_postman_id": "3a927eb8-f535-45d3-8674-9b99ec42fbf8",
    "name": "Social Network API",
    "description": "Postman collection for the social_network service.\n\nEndpoints detected from source code:\n- POST /user/register\n- POST /login\n- GET /user/get/:userId\n\nDefault baseUrl points to the local app port from Main.cpp. If your server is mounted under /social_network, change the baseUrl collection variable to http://127.0.0.1:8001/social_network.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set('userId', jsonData.id);",
                  "}",
                  "",
                  "pm.test('Response contains created user id', function () {",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Ivan\",\n  \"last_name\": \"Petrov\",\n  \"birthday\": \"1995-04-21\",\n  \"gender\": \"male\",\n  \"interests\": \"coding, music\",\n  \"city\": \"Amsterdam\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "register"
              ]
            },
            "description": "Creates a new user. The service expects birthday in YYYY-MM-DD format."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}",
                  "if (jsonData.user_id) {",
                  "    pm.collectionVariables.set('userId', jsonData.user_id);",
                  "}",
                  "",
                  "pm.test('Response contains JWT token', function () {",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{userId}}\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Authenticates a user by user_id and password. Saves token and userId to collection variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get user by id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/get/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user",
                "get",
                "{{userId}}"
              ]
            },
            "description": "Protected endpoint. Requires Authorization: Bearer {{token}}."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8001",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
